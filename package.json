{
  "name": "octoengine",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source Agent Engineering Control Plane",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "docs:check": "node scripts/check-docs.mjs",
    "octo": "node --experimental-strip-types scripts/octoengine.mjs",
    "validate:schemas": "node scripts/validate-schemas.mjs",
    "test": "node --experimental-strip-types --test \"packages/**/*.test.mjs\" \"test/**/*.test.mjs\"",
    "format": "prettier --write ."
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^6.0.3"
  }
}
