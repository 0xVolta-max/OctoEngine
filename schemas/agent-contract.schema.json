{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OctoEngine Agent Contract",
  "type": "object",
  "required": [
    "id",
    "name",
    "mission",
    "inputs",
    "outputs",
    "forbidden"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "mission": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "escalation_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
